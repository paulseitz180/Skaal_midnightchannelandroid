<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!--
      Site uses 'Courier New', Courier, monospace.
      System monospace stands in until an optional licensed font asset is bundled.
      Compose CrtTextStyles owns the full type scale; this is the window default only.
    -->
    <style name="TextAppearance.MidnightChannel" parent="android:TextAppearance">
        <item name="android:fontFamily">monospace</item>
        <item name="android:textColor">@color/crt_on_background</item>
        <item name="android:textSize">@dimen/text_body</item>
        <item name="android:textAllCaps">false</item>
        <!-- ~site tap-prompt tracking; Compose tokens carry the full CRT scale. -->
        <item name="android:letterSpacing">0.08</item>
    </style>
</resources>
