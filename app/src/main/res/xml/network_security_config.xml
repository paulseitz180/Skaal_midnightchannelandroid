<?xml version="1.0" encoding="utf-8"?>
<network-security-config>
    <!-- HTTPS-only shell: midnightchannel.live and embed third-parties (e.g. YouTube) must use TLS. -->
    <base-config cleartextTrafficPermitted="false">
        <trust-anchors>
            <certificates src="system" />
        </trust-anchors>
    </base-config>
</network-security-config>
