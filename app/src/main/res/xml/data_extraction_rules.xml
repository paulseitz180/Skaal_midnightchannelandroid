<?xml version="1.0" encoding="utf-8"?>
<!--
  WebView DOM storage / cookies must not leave the device via cloud or device-transfer
  backup. Listening UX is unaffected — only backup/restore of app data is denied.
-->
<data-extraction-rules>
    <cloud-backup>
        <exclude domain="root" />
        <exclude domain="file" />
        <exclude domain="database" />
        <exclude domain="sharedpref" />
        <exclude domain="external" />
    </cloud-backup>
    <device-transfer>
        <exclude domain="root" />
        <exclude domain="file" />
        <exclude domain="database" />
        <exclude domain="sharedpref" />
        <exclude domain="external" />
    </device-transfer>
</data-extraction-rules>
