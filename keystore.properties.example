# Release signing configuration (DO NOT COMMIT — see .gitignore)
#
# Usage:
#   1. Copy this file to keystore.properties at the repository root
#   2. Create a release keystore (or use the Play App Signing upload key)
#   3. Fill in the fields below
#   4. ./gradlew :app:assembleRelease   or   :app:bundleRelease
#
# Codemagic / CI:
#   Prefer Codemagic Code signing (android_signing) which injects CM_KEYSTORE_PATH,
#   CM_KEYSTORE_PASSWORD, CM_KEY_ALIAS, CM_KEY_PASSWORD — no Play Store upload.
#   Or generate keystore.properties in a pre-build script.
#   Never commit the real keystore.

storeFile=path/to/midnightchannel-release.jks
storePassword=CHANGE_ME
keyAlias=midnightchannel
keyPassword=CHANGE_ME
